#
# NOTE: The use of packages is highly recommended instead of houdini.env 
# See details about packages here: https://www.sidefx.com/docs/houdini21.0/ref/plugins.html
#
# Houdini Environment Settings
#
# The contents of this file are read into the environment
# at startup.  They will override any existing entries in
# the environment.
#
# The syntax is one entry per line as follows:
#    VAR = VALUE
#
# Values may be quoted
#    VAR = "VALUE"
#
# Values may be empty
#    VAR = 
#

# Example:
#
# HOUDINI_NO_SPLASH = 1

# Magic Mouse no MMB 
HOUDINI_MMB_PAN=0

# OTLs 
QLIB=/Users/izzy/HDA/qLib-master/otls
AXIS=/Users/izzy/HDA/AxisTools/otls
IZZY=/Users/izzy/HDA/otls
HOUDINI_OTLSCAN_PATH=@/otls;$QLIB/base;$QLIB/future;$QLIB/experimental;$AXIS;$IZZY;$HOUDINI_PATH;&

HOUDINI_TEMP_DIR = "/Volumes/izzySdPro/tempfiles"
